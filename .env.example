# Story Phone — Wolt Net Income admin credentials
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Local dev: dev_server.py loads .env automatically.
# Vercel:    Project → Settings → Environment Variables (same names).

# Required — login will fail until this is set
ADMIN_PASSWORD=your-secure-password-here

# Optional — defaults to "admin"
ADMIN_USERNAME=admin

# Required in production — random string used to sign session tokens
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-to-a-long-random-string

# Optional — session lifetime in seconds (default 86400 = 24 hours)
# AUTH_TOKEN_TTL_SECONDS=86400

# Supabase PostgreSQL (required for saved timelines + commission catalog in DB)
# Supabase → Project Settings → Database → Connection string → URI
# Use "Transaction" pooler for serverless (port 6543) or direct connection for local dev.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional — local xlsx fallback when DATABASE_URL is unset or catalog empty
# OFFERS_XLSX_PATH=data/offers_commission.xlsx
