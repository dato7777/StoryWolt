{
  "version": 2,
  "installCommand": "pip install -r requirements.txt && cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/login", "destination": "/api/login.py" },
    { "source": "/api/session", "destination": "/api/session.py" },
    { "source": "/api/calculate", "destination": "/api/calculate.py" },
    { "source": "/api/health", "destination": "/api/health.py" }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.12"
    }
  }
}
